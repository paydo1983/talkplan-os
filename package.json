{
  "name": "talkplan-os",
  "version": "1.0.2",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "vite build && electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "firebase": "^11.0.0",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.11",
    "vite": "^5.4.2",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.talkplan.os",
    "productName": "TalkPlanOS",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "main.cjs"],
    "publish": [
      {
        "provider": "github",
        "owner": "paydo1983",
        "repo": "talkplan-os"
      }
    ],
    "win": { "target": ["nsis"] },
    "nsis": { 
      "oneClick": false, 
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "TalkPlanOS"
    }
  }
}